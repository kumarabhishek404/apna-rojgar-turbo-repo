{
  "name": "apna-rojgar",
  "private": true,
  "scripts": {
    "prepare": "pnpm --filter @repo/common run build",
    "dev": "turbo run dev",
    "dev:website": "pnpm --filter apna-rojgar-website dev",
    "dev:backend": "pnpm --filter apna-rojgar-backend dev",
    "dev:mobile": "pnpm --filter labour-app dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "deploy": "bash scripts/deploy.sh",
    "push-deploy": "bash scripts/push-deploy.sh"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18"
  }
}
