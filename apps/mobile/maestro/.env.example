# Copy to .env and fill in your staging test account mobiles (10 digits, no +91)
# cp .env.example .env
# Or run pnpm test:maestro:smoke once — .env is auto-created from this file

APP_ID=com.kumarabhishek404.labourapp
STAGING_OTP=000000

# Required for smoke tests (10-digit staging account with complete profile)
WORKER_MOBILE=6397308499

# Required for regression (can use same number for all in dev)
EMPLOYER_MOBILE=6397308499
MEDIATOR_MOBILE=6397308499
ADMIN_MOBILE=6397308499

# Optional — deep link tests
SAMPLE_JOB_ID=

# Expo dev client (debug APK) — Metro on host :8081, adb reverse required on physical devices
EXPO_DEV_CLIENT_URL=exp+labour-app://expo-development-client/?url=http%3A%2F%2Flocalhost%3A8081
