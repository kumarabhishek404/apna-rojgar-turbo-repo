# --- OTP / login (see `utils/devOtp.ts`) ---
# __DEV__: true in Expo dev, false in release builds — not set via .env.
# EXPO_PUBLIC_SKIP_OTP: optional. Omit = defaults in devOtp.ts (dev skips OTP unless set false).

EXPO_PUBLIC_SKIP_OTP=true   # uncomment ONLY for local dev with a backend that accepts 000000

# Cashfree environment for mobile SDK (SANDBOX | PRODUCTION)
# SANDBOX for dev APK builds. Use PRODUCTION only with Play Store install.
EXPO_PUBLIC_CASHFREE_ENV=SANDBOX