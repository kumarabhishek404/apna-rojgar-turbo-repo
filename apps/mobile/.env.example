# Copy to `.env` for Expo (do not commit secrets).

# Production API
# EXPO_PUBLIC_BASE_URL=https://api.apnarojgarindia.com/api/v1

# --- OTP / login UI (`utils/devOtp.ts`) ---
# __DEV__ is set by Metro/Expo (true in dev client, false in release builds). Not configurable via .env.
#
# Production / Play Store release:
# EXPO_PUBLIC_CASHFREE_ENV=PRODUCTION
# EXPO_PUBLIC_SKIP_OTP=false
#
# Local / dev APK against a sandbox backend:
# EXPO_PUBLIC_CASHFREE_ENV=SANDBOX
# EXPO_PUBLIC_SKIP_OTP=true
#
# Optional: only needed to override defaults:
# EXPO_PUBLIC_SKIP_OTP=false   # in __DEV__, require real send+verify against your API
