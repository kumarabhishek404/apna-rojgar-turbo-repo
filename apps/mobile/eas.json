{
  "cli": {
    "version": ">= 12.3.0",
    "appVersionSource": "local"
  },
  "build": {
    "production": {
      "environment": "production",
      "node": "20.19.4",
      "android": {
        "buildType": "app-bundle"
      },
      "channel": "production"
    },
    "development": {
      "environment": "development",
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "NODE_ENV": "development"
      },
      "channel": "development"
    },
    "preview": {
      "environment": "preview",
      "android": {
        "buildType": "apk"
      },
      "channel": "preview"
    },
    "release": {
      "environment": "release",
      "android": {
        "gradleCommand": ":app:bundleRelease"
      },
      "channel": "release"
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-services-account.json",
        "track": "internal"
      }
    }
  }
}
