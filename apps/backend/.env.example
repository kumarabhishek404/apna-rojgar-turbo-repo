# Copy to .env / .env.local / .env.production as needed (never commit real secrets).
# Loading order (see index.js): .env first, then .env.local (dev) or .env.production (prod) overrides.

# OTP / 2factor.in — required for real SMS outside dev bypass
# TWOFACTOR_API_KEY=
# DLT-registered template name in 2factor dashboard (default in code: temp1)
# TWOFACTOR_TEMPLATE_NAME=temp1

# Dev only: OTP bypass. Put these in .env.local only — never in base .env or .env.production.
# DEV_BYPASS_OTP=true
# SKIP_OTP=true
# Force real 2factor SMS even when dev bypass would otherwise be enabled.
# OTP_FORCE_LIVE=true

# Cashfree Payment Gateway (service social media promotion)
# Sandbox (development): CASHFREE_ENV=sandbox + Test API keys from Cashfree dashboard
# Production: CASHFREE_ENV=production + Production API keys + CASHFREE_FORCE_LIVE=true
# CASHFREE_CLIENT_ID=
# CASHFREE_CLIENT_SECRET=
# CASHFREE_ENV=sandbox
# SERVICE_PROMOTION_AMOUNT=100
# Dev only when keys are not set (local / Render dev): auto-skips Cashfree checkout
# CASHFREE_DEV_BYPASS=true
# Force real Cashfree even in development (when keys are configured)
# CASHFREE_FORCE_LIVE=true
# Optional dev-only webhook bypass (never use in production)
# CASHFREE_WEBHOOK_SKIP_VERIFY=true
# Webhook URL to configure in Cashfree dashboard:
# https://<your-api-host>/api/v1/payments/webhook/cashfree

# --- Production host checklist (Render / Railway dashboard) ---
# NODE_ENV=production
# DEV_BYPASS_OTP=false
# SKIP_OTP=false
# OTP_FORCE_LIVE=true
# CASHFREE_DEV_BYPASS=false
# CASHFREE_FORCE_LIVE=true
# CASHFREE_ENV=production
# TWOFACTOR_API_KEY=<your 2factor key>
# CASHFREE_CLIENT_ID / CASHFREE_CLIENT_SECRET = production keys

# Weekly registration export to Google Sheets
# GOOGLE_SHEETS_ENABLED=true
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# GOOGLE_SHEETS_SHARE_WITH_EMAIL=
# Recommended: create a sheet in your Gmail, share it with GOOGLE_SERVICE_ACCOUNT_EMAIL
# as Editor, then paste the sheet ID from the URL here (service accounts cannot store new files).
# GOOGLE_SHEETS_SPREADSHEET_ID=
# CRON_WEEKLY_REGISTRATIONS_ENABLED=true
# Weekly services export (separate Google Sheet)
# GOOGLE_SHEETS_SERVICES_SPREADSHEET_ID=
# CRON_WEEKLY_SERVICES_ENABLED=true
