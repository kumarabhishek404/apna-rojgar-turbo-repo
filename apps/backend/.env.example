# Copy to .env / .env.local / .env.production as needed (never commit real secrets).

# OTP / 2factor.in — required for real SMS outside dev bypass
# TWOFACTOR_API_KEY=
# DLT-registered template name in 2factor dashboard (default in code: temp1)
# TWOFACTOR_TEMPLATE_NAME=temp1

# Dev only: OTP bypass when NODE_ENV=development (set false to test real SMS locally)
# DEV_BYPASS_OTP=true
# Force real 2factor SMS even when NODE_ENV=development
# OTP_FORCE_LIVE=true

# Send OTP returns otpSessionId to clients; verify should pass it back (required behind load balancers).
