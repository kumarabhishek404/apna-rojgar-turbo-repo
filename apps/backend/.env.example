# Shared secrets — copy to `.env` (never commit real secrets).
# Same files on Cursor and EC2. Mode is chosen by the start script, not by editing the server.
#
#   Local (Cursor):  npm run dev   → loads .env + .env.local      → DEVELOPMENT_DB_NAME
#   Production EC2:  npm start     → loads .env + .env.production → PRODUCTION_DB_NAME
#
# Sync Cursor env → GitHub → EC2 (no SSH editing):
#   ./scripts/sync-backend-env-secrets.sh

# MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net
# DEVELOPMENT_DB_NAME=LOCAL_LABOUR_APP
# PRODUCTION_DB_NAME=LABOUR_APP
# JWT_SECRET=

# OTP / 2factor.in
# TWOFACTOR_API_KEY=
# TWOFACTOR_TEMPLATE_NAME=temp1

# Dev-only (put in .env.local, not here):
# DEV_BYPASS_OTP=true
# SKIP_OTP=true
